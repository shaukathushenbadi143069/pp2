#include<stdio.h>
#include<conio.h>

int main(){
    int n, i, a[100];
    int sum = 0;
    float avg;
       printf("Enter number of elements: ");
       scanf("%d", &n);
       printf("Enter %d elements:\n",n);
       for(i = 0; i < n; i++){
	  scanf("%d", &a[i]);
	  sum += a[i];
       }
       avg = (float)sum / n;
       printf("Total = %d\n", sum);
       printf("Average = %.2f\n", avg);

       return 0;
       }
